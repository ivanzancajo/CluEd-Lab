PORT=4000
ADMIN_USER=admin
ADMIN_PASS_HASH=
JWT_SECRET=
# Desarrollo local fuera de Docker:
# DATABASE_URL=postgresql://cluedo_admin:TU_PASSWORD@localhost:5432/cluedo_db?schema=public
# Produccion en MV Linux con PostgreSQL en el host:
DATABASE_URL=postgresql://cluedo_admin:TU_PASSWORD@host.docker.internal:5432/cluedo_db?schema=public
ALLOWED_ORIGINS=http://IP_O_DNS_PUBLICO_DE_LA_MV:8080
# Opcional: si no se define, Socket.io reutiliza ALLOWED_ORIGINS.
SOCKET_IO_CORS_ORIGIN=http://IP_O_DNS_PUBLICO_DE_LA_MV:8080
# Si expones la app temporalmente con un tunel HTTPS, añade tambien ese origen separado por comas.
# ALLOWED_ORIGINS=http://IP_O_DNS_PUBLICO_DE_LA_MV:8080,https://tu-subdominio.trycloudflare.com
# SOCKET_IO_CORS_ORIGIN=http://IP_O_DNS_PUBLICO_DE_LA_MV:8080,https://tu-subdominio.trycloudflare.com