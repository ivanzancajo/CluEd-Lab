generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ColorEquipo {
  ROJO
  AZUL
  VERDE
  AMARILLO
  MORADO
  BLANCO

  @@map("color_equipo")
}

enum EstadoDeduccion {
  NEUTRO
  DUDA
  DESCARTADO

  @@map("estado_deduccion")
}

enum TipoEvento {
  MOVIMIENTO
  SUGERENCIA
  REFUTACION
  ACUSACION
  SISTEMA

  @@map("tipo_evento")
}

enum TipoElemento {
  SUJETO
  OBJETO
  ESPACIO

  @@map("tipo_elemento")
}

enum EstadoPartida {
  LOBBY
  REPARTO
  EN_CURSO
  PAUSADA
  FINALIZADA

  @@map("estado_partida")
}

model CluedoSkin {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_skin")
  name                String                @map("nombre") @db.VarChar(100)
  objective           String?               @map("objetivo")
  context             String?               @map("contexto")
  imageUrl            String?               @map("imagen")

  partidas            Partida[]
  elementDescriptions DescripcionElemento[]

  @@map("cluedo_skin")
}

model Elemento {
  id               String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_elem")
  name             String                @map("nombre") @db.VarChar(50)
  kind             TipoElemento          @map("tipo_elem")
  imageUrl         String?               @map("imagen")

  skinDescriptions DescripcionElemento[]
  reasoningCells   CeldaRazonamiento[]
  subjectSolutions Solucion[]            @relation("SolutionSubject")
  objectSolutions  Solucion[]            @relation("SolutionObject")
  spaceSolutions   Solucion[]            @relation("SolutionSpace")

  @@map("elemento")
}

model DescripcionElemento {
  skinId      String     @db.Uuid @map("id_skin")
  elementId   String     @db.Uuid @map("id_elem")
  description String?    @map("descripcion")
  motif       String?    @map("motivo")

  skin        CluedoSkin @relation(fields: [skinId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  element     Elemento   @relation(fields: [elementId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([skinId, elementId])
  @@map("descripcion_elemento")
}

model Solucion {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_solucion")
  subjectElementId String?   @db.Uuid @map("id_sujeto")
  objectElementId  String?   @db.Uuid @map("id_objeto")
  spaceElementId   String?   @db.Uuid @map("id_espacio")

  subject          Elemento? @relation("SolutionSubject", fields: [subjectElementId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  object           Elemento? @relation("SolutionObject", fields: [objectElementId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  space            Elemento? @relation("SolutionSpace", fields: [spaceElementId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partidas         Partida[]

  @@map("solucion")
}

model Partida {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_partida")
  accessCode String     @map("codigo_acceso") @db.VarChar(6)
  status     EstadoPartida? @default(LOBBY) @map("estado")
  skinId     String?      @db.Uuid @map("id_skin")
  solutionId String?      @db.Uuid @map("id_solucion")

  skin       CluedoSkin? @relation(fields: [skinId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  solution   Solucion?   @relation(fields: [solutionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teams      Equipo[]
  events     Evento[]

  @@unique([accessCode], map: "partida_codigo_acceso_key")
  @@map("partida")
}

model Equipo {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_equipo")
  partidaId        String?             @db.Uuid @map("id_partida")
  name             String              @map("nombre") @db.VarChar(20)
  color            ColorEquipo         @map("color")
  positionX        Int?                @default(0) @map("pos_x")
  positionY        Int?                @default(0) @map("pos_y")
  falseAccusation  Boolean?            @default(false) @map("acusacion_falsa")

  partida          Partida?            @relation(fields: [partidaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  emittedEvents    Evento[]            @relation("EventEmitter")
  receivedEvents   Evento[]            @relation("EventReceiver")
  reasoningTables  TablaRazonamiento[]

  @@map("equipo")
}

model TablaRazonamiento {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_tabla")
  equipoId         String?             @db.Uuid @map("id_equipo")
  progress         Decimal?            @default(0.00) @map("progreso") @db.Decimal(5, 2)

  equipo           Equipo?             @relation(fields: [equipoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  annotations      Anotacion[]
  cells            CeldaRazonamiento[]

  @@map("tabla_razonamiento")
}

model Anotacion {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_anotacion")
  tablaId          String?             @db.Uuid @map("id_tabla")
  content          String?             @map("contenido")

  tabla            TablaRazonamiento?  @relation(fields: [tablaId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("anotacion")
}

model CeldaRazonamiento {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_celda")
  tablaId          String?             @db.Uuid @map("id_tabla")
  elementId        String?             @db.Uuid @map("id_elem")
  deductionState   EstadoDeduccion?    @default(NEUTRO) @map("estado_deduc")

  tabla            TablaRazonamiento?  @relation(fields: [tablaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  element          Elemento?           @relation(fields: [elementId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("celda_razonamiento")
}

model Evento {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid @map("id_evento")
  partidaId        String?             @db.Uuid @map("id_partida")
  emitterId        String?             @db.Uuid @map("id_emisor")
  receiverId       String?             @db.Uuid @map("id_receptor")
  eventType        TipoEvento          @map("tipo_evento")
  detail           Json?               @map("detalle")
  occurredAt       DateTime?           @default(now()) @map("timestamp") @db.Timestamp(6)

  partida          Partida?            @relation(fields: [partidaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  emitter          Equipo?             @relation("EventEmitter", fields: [emitterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  receiver         Equipo?             @relation("EventReceiver", fields: [receiverId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("evento")
}