# Copia este archivo a .deploy/mv.backend.env en la MV y rellena los valores.
# El script scripts/deploy-mv.sh lo usa para regenerar backend/.env y
# docker-compose.lab.env en cada despliegue.

PORT=4000
ADMIN_USER=admin
ADMIN_PASS_HASH=$2b$10$REEMPLAZA_ESTE_HASH_BCRYPT
JWT_SECRET=REEMPLAZA_ESTE_SECRETO
DATABASE_URL=postgresql://cluedo_admin:TU_PASSWORD@host.docker.internal:5432/cluedo_db?schema=public
ALLOWED_ORIGINS=http://virtual.lab.inf.uva.es:20382,http://vm2038.virtual.lab.inf.uva.es
SOCKET_IO_CORS_ORIGIN=http://virtual.lab.inf.uva.es:20382,http://vm2038.virtual.lab.inf.uva.es

FRONTEND_HOST_IP=0.0.0.0
FRONTEND_PUBLISHED_PORT=80
BACKEND_HOST_IP=127.0.0.1
BACKEND_PUBLISHED_PORT=4000

# ── Túnel Cloudflare (opcional, necesario para acceso desde Eduroam) ──────────
# Token del túnel nombrado. Genera el tunel una vez con:
#   cloudflared tunnel create cluedo-tfg
#   cloudflared tunnel token cluedo-tfg
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiM...
#
# URL pública fija del túnel (del Cloudflare Dashboard, Public Hostname configurado → localhost:80)
# CLOUDFLARE_TUNNEL_URL=https://cluedo-tfg.example.workers.dev