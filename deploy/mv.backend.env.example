# Copia este archivo a .deploy/mv.backend.env en la MV y rellena los valores.
# El script scripts/deploy-mv.sh lo usa para regenerar backend/.env y
# docker-compose.lab.env en cada despliegue.

PORT=4000
ADMIN_USER=admin
ADMIN_PASS_HASH=$2b$10$REEMPLAZA_ESTE_HASH_BCRYPT
JWT_SECRET=REEMPLAZA_ESTE_SECRETO
DATABASE_URL=postgresql://cluedo_admin:TU_PASSWORD@host.docker.internal:5432/cluedo_db?schema=public

# El frontend sirve HTTP en :20382 (NAT lab: externo :20382 → VM:80).
# El script añade automaticamente la URL del tunnel a estas variables cuando
# CLOUDFLARE_QUICK_TUNNEL=true o CLOUDFLARE_TUNNEL_TOKEN esta definido.
ALLOWED_ORIGINS=https://virtual.lab.inf.uva.es:20382
SOCKET_IO_CORS_ORIGIN=https://virtual.lab.inf.uva.es:20382

# El frontend se publica internamente en :8080; nginx del host lo proxea en :80.
FRONTEND_HOST_IP=127.0.0.1
FRONTEND_PUBLISHED_PORT=8080
BACKEND_HOST_IP=127.0.0.1
BACKEND_PUBLISHED_PORT=4000

# ── Cloudflare Tunnel para acceso desde Eduroam (elige una opcion) ──────────
#
# Opcion A — Quick Tunnel (sin cuenta ni dominio, URL cambia si el contenedor
# se reinicia). El script extrae la URL de los logs y actualiza CORS solo.
# CLOUDFLARE_QUICK_TUNNEL=true
#
# Opcion B — Named Tunnel (cuenta gratuita de Cloudflare + dominio, URL estable).
# Obtén el token en: Zero Trust → Networks → Tunnels → token del tunnel.
# CLOUDFLARE_TUNNEL_TOKEN=<token-del-tunel>
# CLOUDFLARE_TUNNEL_URL=https://<public-hostname-configurado>
