# Copia este archivo a .deploy/mv.backend.env en la MV y rellena los valores.
# El script scripts/deploy-mv.sh lo usa para regenerar backend/.env y
# docker-compose.lab.env en cada despliegue.

PORT=4000
ADMIN_USER=admin
ADMIN_PASS_HASH=$2b$10$REEMPLAZA_ESTE_HASH_BCRYPT
JWT_SECRET=REEMPLAZA_ESTE_SECRETO
DATABASE_URL=postgresql://cluedo_admin:TU_PASSWORD@host.docker.internal:5432/cluedo_db?schema=public

# El frontend sirve HTTP en :20382 (NAT lab: externo :20382 → VM:80).
# Cuando el Cloudflare Tunnel esta activo el script añade CLOUDFLARE_TUNNEL_URL
# automaticamente a estas variables para que el backend acepte ambos origenes.
ALLOWED_ORIGINS=http://virtual.lab.inf.uva.es:20382
SOCKET_IO_CORS_ORIGIN=http://virtual.lab.inf.uva.es:20382

# El frontend se publica internamente en :8080; nginx del host lo proxea en :80.
FRONTEND_HOST_IP=127.0.0.1
FRONTEND_PUBLISHED_PORT=8080
BACKEND_HOST_IP=127.0.0.1
BACKEND_PUBLISHED_PORT=4000

# Cloudflare Named Tunnel para acceso desde Eduroam (opcional).
# Crea el tunel en cloudflare.com, obtén el token con:
#   cloudflared tunnel token <nombre-tunel>
# y anota la URL publica del Public Hostname configurado en el dashboard.
# Con ambas variables definidas el script activa el perfil 'tunnel' de
# Docker Compose y añade CLOUDFLARE_TUNNEL_URL a ALLOWED_ORIGINS.
# CLOUDFLARE_TUNNEL_TOKEN=<token-del-tunel>
# CLOUDFLARE_TUNNEL_URL=https://<subdominio>.workers.dev
