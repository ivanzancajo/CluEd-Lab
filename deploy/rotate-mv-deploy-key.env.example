# Copia este archivo a .deploy/rotate-mv-deploy-key.env y ajusta los valores locales.

ROTATE_MV_KEY_HOST=virtual.lab.inf.uva.es
ROTATE_MV_KEY_PORT=20381
ROTATE_MV_KEY_USER=usuario

# Opcional. Si no se indica, se deriva de origin cuando haga falta usar gh.
ROTATE_MV_KEY_REPO_SLUG=ivanzancajo/TFG-Cluedo

# Ruta de la clave bootstrap actual, usada para entrar en la MV durante la rotacion.
ROTATE_MV_KEY_BOOTSTRAP_IDENTITY=~/.ssh/id_ed25519_tfg_mv_actions

# Ruta base de la nueva clave que se generara.
ROTATE_MV_KEY_KEY_PATH=~/.ssh/id_ed25519_tfg_mv_actions_rotacion

# Comentario de la nueva clave.
ROTATE_MV_KEY_COMMENT=github-actions-rotacion-tfg-mv

# Secreto GitHub a actualizar.
ROTATE_MV_KEY_SECRET_NAME=MV_SSH_PRIVATE_KEY_B64

# Workflow a relanzar para validar la nueva clave.
ROTATE_MV_KEY_WORKFLOW_NAME=deploy-mv-lab.yml
ROTATE_MV_KEY_WORKFLOW_REF=develop
ROTATE_MV_KEY_WORKFLOW_INPUT_REF=develop

# Comentario de la clave antigua a retirar de authorized_keys una vez validado el workflow.
ROTATE_MV_KEY_RETIRE_COMMENT=github-actions-tfg-mv

# Ruta base de la clave antigua local a borrar tras validar el workflow.
ROTATE_MV_KEY_DELETE_OLD_LOCAL_KEY=~/.ssh/id_ed25519_tfg_mv_actions