# El frontend solo es accesible desde el propio host; el nginx del host lo
# proxea con TLS y lo expone como https://virtual.lab.inf.uva.es:20382.
FRONTEND_HOST_IP=127.0.0.1
FRONTEND_PUBLISHED_PORT=8080

# El backend solo es accesible desde el propio host; el nginx del host lo
# proxea en /api/ y /socket.io/.
BACKEND_HOST_IP=127.0.0.1
BACKEND_PUBLISHED_PORT=4000