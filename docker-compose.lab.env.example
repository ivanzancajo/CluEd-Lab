# Publica el frontend en el puerto 80 interno de la MV para que quede accesible
# desde el exterior como http://virtual.lab.inf.uva.es:20382.
FRONTEND_HOST_IP=0.0.0.0
FRONTEND_PUBLISHED_PORT=80

# Mantiene el backend accesible solo desde la propia MV; nginx del frontend lo
# sigue alcanzando por la red interna de Docker Compose.
BACKEND_HOST_IP=127.0.0.1
BACKEND_PUBLISHED_PORT=4000